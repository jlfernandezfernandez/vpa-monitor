# Vivienda Coruña — Configuración del Rastreador y LLM (Ejemplo)
# -----------------------------------------------------------------------------
# Copia este archivo a .env y añade tu API Key:
#   cp .env.example .env
#
# Registra tu API Key en OpenRouter (https://openrouter.ai):
LLM_API_KEY=

# Dirección base de la API de completado compatible con OpenAI (por defecto OpenRouter)
LLM_BASE_URL=https://openrouter.ai/api/v1

# Modelo sugerido para Structured Outputs en OpenRouter:
#   - Recomendado: openai/gpt-4o-mini
#   - Alternativa: google/gemini-2.5-flash
LLM_MODEL=openai/gpt-4o-mini
