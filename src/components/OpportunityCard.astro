---
export interface Props {
  title: string;
  url: string;
  source: string;
  sourceKind?: string;
  publishedAt: string | null;
  firstSeenAt: string;
  location: string;
  type: string;
  status: string | null;
  summary: string;
}

const { title, url, source, sourceKind = 'official', publishedAt, firstSeenAt, location, type, status, summary } = Astro.props;
const date = new Date(publishedAt || firstSeenAt).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class="opportunity">
  <div class="opportunity__meta">
    <span class="eyebrow">{location}</span>
    <time datetime={publishedAt || firstSeenAt}>{date}</time>
  </div>

  <h2><a href={url} target="_blank" rel="noopener noreferrer">{title}</a></h2>
  {summary && <p class="opportunity__summary">{summary}</p>}

  <div class="opportunity__footer">
    <div class="opportunity__tags">
      <span>{type}</span>
      {status && <span>{status}</span>}
      {sourceKind === 'market-alert' && <span class="tag--alert">Alerta de mercado · verificar</span>}
      <span>{source}</span>
    </div>
    <a class="text-link" href={url} target="_blank" rel="noopener noreferrer">
      {sourceKind === 'market-alert' ? 'Ver publicación' : 'Abrir expediente'}
      <svg aria-hidden="true" viewBox="0 0 16 16"><path d="M5 11 11 5M6 5h5v5" /></svg>
    </a>
  </div>
</article>
