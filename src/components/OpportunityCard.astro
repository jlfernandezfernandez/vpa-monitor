---
export interface Props {
  title: string;
  url: string;
  source: string;
  sourceKind?: string;
  publishedAt: string | null;
  firstSeenAt: string;
  location: string;
  type: string;
  status: string | null;
  summary: string;
}

const { title, url, source, sourceKind = 'official', publishedAt, firstSeenAt, location, type, status } = Astro.props;
const sourceLabel = sourceKind === 'market-alert' ? 'Prensa local' : source;
const date = new Date(publishedAt || firstSeenAt).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class="opportunity">
  <div class="opportunity__meta">
    <span>{location}</span>
    <time datetime={publishedAt || firstSeenAt}>{date}</time>
  </div>
  <h3><a href={url} target="_blank" rel="noopener noreferrer">{title}</a></h3>
  <div class="opportunity__footer">
    <div class="opportunity__tags">
      <span>{type}</span>
      {status && <span>{status}</span>}
      <span>{sourceLabel}</span>
    </div>
    <a class="text-link" href={url} target="_blank" rel="noopener noreferrer">
      {sourceKind === 'market-alert' ? 'Abrir' : 'Expediente'}
      <svg aria-hidden="true" viewBox="0 0 16 16"><path d="M5 11 11 5M6 5h5v5" /></svg>
    </a>
  </div>
</article>
