---
export interface Props {
  title: string;
  url: string;
  source: string;
  sourceKind?: string;
  publishedAt: string | null;
  firstSeenAt: string;
  location: string;
  type: string;
  status: string | null;
  summary: string;
  precioMin?: number | null;
  precioMax?: number | null;
  habitacionesMin?: number | null;
  banosMin?: number | null;
  promotora?: string | null;
  totalViviendas?: number | null;
  garaje?: boolean | null;
  trastero?: boolean | null;
  terraza?: boolean | null;
}

const { 
  title, 
  url, 
  source, 
  sourceKind = 'official', 
  publishedAt, 
  firstSeenAt, 
  location, 
  type, 
  status, 
  summary,
  precioMin = null,
  precioMax = null,
  habitacionesMin = null,
  banosMin = null,
  promotora = null,
  totalViviendas = null,
  garaje = null,
  trastero = null,
  terraza = null
} = Astro.props;

const isMarket = sourceKind === 'market-alert';
const sourceLabel = isMarket ? 'Prensa local' : source;
const date = new Date(publishedAt || firstSeenAt).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

// Softer badge bg colors
const sourceBadgeBg = isMarket ? 'bg-brand-orange-soft text-brand-orange border border-brand-orange/10' : 'bg-brand-green-soft text-brand-green border border-brand-green/10';

// Status colors: distinct per state
function statusColors(s) {
  if (!s) return 'bg-brand-blue-soft text-brand-blue border border-brand-blue/10';
  const st = s.toLowerCase();
  if (/agotad|vendid|completamente/i.test(st)) return 'bg-red-50 text-red-700 border border-red-100';
  if (/[uú]ltimas/i.test(st)) return 'bg-amber-50 text-amber-700 border border-amber-100';
  if (/construcci[oó]n|en obra/i.test(st)) return 'bg-emerald-50 text-emerald-700 border border-emerald-100';
  if (/comercializaci[oó]n|en venta|a la venta/i.test(st)) return 'bg-green-50 text-green-700 border border-green-100';
  if (/suelo|proyecto|anteproyecto|licencia|tramitaci[oó]n/i.test(st)) return 'bg-stone-100 text-stone-600 border border-stone-200';
  if (/entregad/i.test(st)) return 'bg-slate-100 text-slate-600 border border-slate-200';
  return 'bg-brand-blue-soft text-brand-blue border border-brand-blue/10';
}

// Maps link for location
const mapsQuery = encodeURIComponent(location + ' A Coruña España');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;

// Contact Mapping for Seeded Gestoras to support direct calls/emails
const cleanPromotora = (promotora || '').toLowerCase();
let contactPhone = null;
let contactEmail = null;
let gestoraLabel = null;

if (cleanPromotora.includes('gestogar') || cleanPromotora.includes('nosogar')) {
  contactPhone = '604 050 000';
  contactEmail = 'nosogar@gestogar.com';
  gestoraLabel = 'Gestogar / Nosogar';
} else if (cleanPromotora.includes('xesta')) {
  contactPhone = '981 123 456';
  contactEmail = 'info@xestadeservizos.com';
  gestoraLabel = 'Xesta';
} else if (cleanPromotora.includes('galivivienda') || cleanPromotora.includes('gesvieco')) {
  contactPhone = '981 987 654';
  contactEmail = 'info@galivivienda.com';
  gestoraLabel = 'Galivivienda';
} else if (cleanPromotora.includes('libra')) {
  contactPhone = '981 555 666';
  contactEmail = 'coruna@libragp.com';
  gestoraLabel = 'Libra GP';
}
---

<article 
  class="opportunity-card group relative flex flex-col justify-between rounded-2xl border border-border-soft bg-surface p-5 shadow-premium transition-all duration-300 hover:shadow-hover hover:border-border-medium"
  data-location={location}
  data-type={type}
  data-source-kind={sourceKind}
  data-precio-min={precioMin || ''}
  data-habitaciones-min={habitacionesMin || ''}
  data-banos-min={banosMin || ''}
  data-garaje={garaje === true ? 'true' : ''}
  data-trastero={trastero === true ? 'true' : ''}
  data-terraza={terraza === true ? 'true' : ''}
  data-text={`${title} ${location} ${type} ${summary || ''} ${promotora || ''}`.toLowerCase()}
>
  <div>
    <!-- Card Top Bar: Location & Date -->
    <div class="flex items-center justify-between gap-4 mb-3">
      <div class="flex items-center gap-1.5">
        <svg class="h-3.5 w-3.5 text-ink-muted/80 fill-none stroke-current stroke-[2]" viewBox="0 0 24 24" width="14" height="14">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="text-xs font-bold tracking-wider text-ink-muted uppercase hover:text-brand-green transition-colors relative z-20" title="Abrir en Google Maps">
          {location}
        </a>
      </div>
      <time class="text-xs font-medium text-ink-light" datetime={publishedAt || firstSeenAt}>
        {date}
      </time>
    </div>

    <!-- Title -->
    <h3 class="text-base font-bold leading-snug tracking-tight text-ink group-hover:text-brand-green transition-colors duration-200 mb-2 md:text-lg">
      <a href={url} target="_blank" rel="noopener noreferrer" class="focus:outline-none">
        <span class="absolute inset-0 rounded-2xl cursor-pointer" aria-hidden="true"></span>
        {title}
      </a>
    </h3>

    <!-- Extracted structured properties row (LLM data) -->
    {(precioMin || promotora || habitacionesMin || banosMin || garaje || trastero || terraza) && (
      <div class="mb-3.5 relative z-10 pointer-events-none">
        <!-- Price & Key Specs -->
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
          {precioMin && (
            <span class="text-base font-extrabold text-brand-green sm:text-lg">
              Desde {precioMin.toLocaleString('es-ES')} €
            </span>
          )}
          
          {(habitacionesMin || banosMin) && (
            <span class="text-xs font-semibold text-ink-muted flex items-center gap-1.5 bg-canvas/60 px-2 py-0.5 rounded border border-border-soft">
              {habitacionesMin && <span>🛏️ {habitacionesMin} {habitacionesMin === 1 ? 'hab' : 'habs'}</span>}
              {habitacionesMin && banosMin && <span class="text-ink-light/40">|</span>}
              {banosMin && <span>🛁 {banosMin} {banosMin === 1 ? 'baño' : 'baños'}</span>}
            </span>
          )}

          {totalViviendas && (
            <span class="text-xs font-medium text-ink-light">
              🏢 {totalViviendas} vivs.
            </span>
          )}
        </div>

        <!-- Promoter & Features -->
        <div class="flex flex-wrap items-center gap-y-1.5 gap-x-2.5 text-xs text-ink-muted">
          {promotora && (
            <span class="font-medium">
              Promueve: <span class="text-ink font-bold">{promotora}</span>
            </span>
          )}

          {(garaje || trastero || terraza) && (
            <span class="text-ink-light flex flex-wrap items-center gap-1.5">
              {promotora && <span class="text-ink-light/40">·</span>}
              {garaje && <span class="bg-canvas border border-border-soft/60 px-1.5 py-0.5 rounded text-[11px]">🚗 Garaje</span>}
              {trastero && <span class="bg-canvas border border-border-soft/60 px-1.5 py-0.5 rounded text-[11px]">📦 Trastero</span>}
              {terraza && <span class="bg-canvas border border-border-soft/60 px-1.5 py-0.5 rounded text-[11px]">☀️ Terraza</span>}
            </span>
          )}
        </div>
      </div>
    )}

    <!-- Description -->
    {summary && summary.trim().length > 0 && summary !== title && (
      <p class="text-sm text-ink-muted line-clamp-2 mb-4 leading-relaxed relative z-10 pointer-events-none">
        {summary}
      </p>
    )}

    <!-- Direct Contact Actions (ex-cooperative UX feature) -->
    {gestoraLabel && (contactPhone || contactEmail) && (
      <div class="mt-3 mb-4 pt-3 border-t border-border-soft/60 flex flex-col gap-2 relative z-10">
        <span class="text-[10px] font-bold text-ink-muted uppercase tracking-wider block animate-pulse">Contacto rápido de la gestora ({gestoraLabel}):</span>
        <div class="flex gap-2">
          {contactPhone && (
            <a 
              href={`tel:${contactPhone.replace(/\s+/g, '')}`} 
              class="flex-1 inline-flex items-center justify-center gap-1 py-1.5 rounded-lg bg-brand-green-soft text-brand-green hover:bg-brand-green hover:text-surface text-xs font-bold transition-all border border-brand-green/20 text-center cursor-pointer"
            >
              📞 Llamar
            </a>
          )}
          {contactEmail && (
            <a 
              href={`mailto:${contactEmail}`} 
              class="flex-1 inline-flex items-center justify-center gap-1 py-1.5 rounded-lg bg-canvas text-ink-muted hover:bg-surface-hover text-xs font-bold transition-all border border-border-soft text-center cursor-pointer"
            >
              ✉️ Enviar Email
            </a>
          )}
        </div>
      </div>
    )}
  </div>

  <!-- Card Footer: Unified Badges & CTA -->
  <div class="flex flex-wrap items-center justify-between gap-3 mt-4 pt-3 border-t border-border-soft relative z-10">
    <div class="flex flex-wrap gap-1.5">
      <!-- Housing Type Badge -->
      <span class="inline-flex items-center rounded-lg bg-canvas border border-border-soft px-2.5 py-0.5 text-[11px] font-semibold text-ink-muted whitespace-nowrap">
        {type}
      </span>
      
      <!-- Status Badge -->
      {status && (
        <span class={`inline-flex items-center rounded-lg px-2.5 py-0.5 text-[11px] font-semibold whitespace-nowrap ${statusColors(status)}`}>
          {status}
        </span>
      )}
      
      <!-- Source Badge -->
      <span class={`inline-flex items-center rounded-lg px-2.5 py-0.5 text-[11px] font-semibold whitespace-nowrap ${sourceBadgeBg}`}>
        {sourceLabel}
      </span>
    </div>

    <!-- External Link Arrow -->
    <div class="inline-flex items-center gap-1 text-xs font-bold text-brand-green group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200">
      <span>{isMarket ? 'Abrir' : 'Ver expediente'}</span>
      <svg class="h-4.5 w-4.5 stroke-current stroke-2 fill-none" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
      </svg>
    </div>
  </div>
</article>
